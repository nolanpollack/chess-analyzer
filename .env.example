# Database URL for PostgreSQL
DATABASE_URL=postgresql://localhost:5432/chess_analyzer

# ── LLM Configuration ──────────────────────────────────────────────────
# Provider: "anthropic" (default) or "openai"
# The "openai" provider also works with any OpenAI-compatible API (Ollama, LM Studio, etc.)
LLM_PROVIDER=anthropic

# Override the default model for the chosen provider
# Defaults: anthropic → claude-sonnet-4-6, openai → gpt-4o
# LLM_MODEL=claude-sonnet-4-6

# Override the base URL (for local LLMs)
# Example for Ollama: http://localhost:11434/v1
# LLM_BASE_URL=

# API keys (only the key for your chosen provider is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Stockfish search depth per position (default: 12, higher = more accurate but slower)
# Depth 12: fast (~0.1s/pos), Depth 15: moderate (~0.5s/pos), Depth 18: slow (~3s/pos)
ANALYSIS_ENGINE_DEPTH=12
